#!/usr/bin/env sh
set -u

PATH="/data/data/com.termux/files/usr/bin:/system/bin:/system/xbin:${PATH:-}"
tmp_dir="${TMPDIR:-/data/data/com.termux/files/usr/tmp}"

command -v kew-now-playing >/dev/null 2>&1 || exit 0

if command -v pgrep >/dev/null 2>&1 && ! pgrep -x kew >/dev/null 2>&1; then
	exit 0
fi

find_kew_socket() {
	for dir in "$tmp_dir" "/data/data/com.termux/files/usr/tmp" "/data/data/com.termux/files/usr/var/run" "$HOME/.tmp" "$HOME/.cache"; do
		[ -d "$dir" ] || continue
		for sock in "$dir"/dbus-*; do
			[ -S "$sock" ] || continue
			if DBUS_SESSION_BUS_ADDRESS="unix:path=$sock" dbus-send --session --dest=org.freedesktop.DBus --type=method_call --print-reply \
				/org/freedesktop/DBus org.freedesktop.DBus.ListNames 2>/dev/null | grep -q 'org.mpris.MediaPlayer2.kew'; then
				printf '%s' "$sock"
				return 0
			fi
		done
	done

	if [ -n "${DBUS_SESSION_BUS_ADDRESS:-}" ] &&
		dbus-send --session --dest=org.freedesktop.DBus --type=method_call --print-reply \
			/org/freedesktop/DBus org.freedesktop.DBus.ListNames 2>/dev/null | grep -q 'org.mpris.MediaPlayer2.kew'; then
		printf '%s' "${DBUS_SESSION_BUS_ADDRESS#unix:path=}"
		return 0
	fi

	return 1
}

is_playing() {
	command -v dbus-send >/dev/null 2>&1 || return 2
	command -v grep >/dev/null 2>&1 || return 2

	sock="$(find_kew_socket)" || return 2
	DBUS_SESSION_BUS_ADDRESS="unix:path=$sock" dbus-send --session --print-reply --dest=org.mpris.MediaPlayer2.kew \
		/org/mpris/MediaPlayer2 org.freedesktop.DBus.Properties.Get \
		string:org.mpris.MediaPlayer2.Player string:PlaybackStatus 2>/dev/null |
		grep -q 'string "Playing"'
}

if is_playing; then
	kew-now-playing 2>/dev/null || true
else
	case "$?" in
		2)
			kew-now-playing 2>/dev/null || true
			;;
	esac
fi
