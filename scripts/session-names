#!/system/bin/sh
set -eu

next_numeric_session() {
	n=1
	while tmux has-session -t "=${n}" 2>/dev/null; do
		n=$((n + 1))
	done
	printf '%s' "$n"
}

normalize_current() {
	current="$(tmux display-message -p '#S' 2>/dev/null || true)"
	normalize_session "$current"
}

normalize_session() {
	session_name="${1:-}"
	[ "$session_name" = 0 ] || return 0
	tmux rename-session -t '=0' "$(next_numeric_session)" 2>/dev/null || true
}

new_session() {
	cwd="$(tmux display-message -p '#{pane_current_path}' 2>/dev/null || printf '%s' "$HOME")"
	name="$(next_numeric_session)"
	tmux new-session -d -s "$name" -c "$cwd"
	tmux switch-client -t "=${name}"
}

case "${1:-new}" in
	normalize-current)
		normalize_current
		;;
	normalize-session)
		normalize_session "${2:-}"
		;;
	new)
		new_session
		;;
	*)
		exit 1
		;;
esac
