#!/usr/bin/env sh
set -u

mode="${TERMUX_LAUNCHER_TMUX_WEATHER_MODE:-compact}"
cache="${XDG_CACHE_HOME:-$HOME/.cache}/launcher-weather-widget.json"
max_age="${LAUNCHER_WEATHER_MAX_AGE:-900}"
weather_url="${LAUNCHER_WEATHER_URL:-https://wttr.in/?format=j1}"

cache_mtime() {
	stat -c %Y "$cache" 2>/dev/null || printf '0'
}

cache_is_fresh() {
	[ -r "$cache" ] || return 1
	age=$(($(date +%s) - $(cache_mtime)))
	[ "$age" -ge 0 ] && [ "$age" -le "$max_age" ]
}

refresh_cache() {
	command -v curl >/dev/null 2>&1 || return 1
	command -v jq >/dev/null 2>&1 || return 1
	mkdir -p "$(dirname "$cache")" 2>/dev/null || return 1

	tmp="${cache}.$$"
	if curl -fsS --connect-timeout 4 --max-time 8 "$weather_url" > "$tmp" 2>/dev/null &&
		jq -e '.current_condition[0].temp_C' "$tmp" >/dev/null 2>&1; then
		mv "$tmp" "$cache"
		return 0
	fi

	rm -f "$tmp"
	return 1
}

ensure_cache() {
	cache_is_fresh || refresh_cache || [ -r "$cache" ]
}

fallback() {
	if command -v launcher-weather-widget >/dev/null 2>&1; then
		weather="$(launcher-weather-widget 2>/dev/null || true)"
	else
		weather=''
	fi
	if [ -n "$weather" ]; then
		printf '%s' "$weather"
	elif ensure_cache && command -v jq >/dev/null 2>&1; then
		weather="$(jq -r '.current_condition[0] | "¾░ûÉ " + (.temp_C | tostring) + "┬░"' "$cache" 2>/dev/null || true)"
		if [ -n "$weather" ] && [ "$weather" != "null" ]; then
			printf '%s' "$weather"
		else
			printf '¾░ûÉ --'
		fi
	else
		printf '¾░ûÉ --'
	fi
}

case "$mode" in
	condition|full|verbose)
		ensure_cache >/dev/null 2>&1 || fallback >/dev/null
		if [ -r "$cache" ] && command -v jq >/dev/null 2>&1; then
			hour="$(date +%H)"
			if [ "$hour" -ge 18 ] || [ "$hour" -lt 6 ]; then
				night=1
			else
				night=0
			fi

			jq -r --arg night "$night" '
				def n: $night == "1";
				def icon($code):
					if ["113"] | index($code) then if n then "¾░ûö" else "¾░ûÖ" end
					elif ["116"] | index($code) then if n then "¯ı╣" else "¾░ûò" end
					elif ["119", "122"] | index($code) then if n then "¯ı¥" else "¾░ûÉ" end
					elif ["143", "248", "260"] | index($code) then if n then "¯ıå" else "¾░ûæ" end
					elif ["176", "263", "266", "293", "296", "299", "302", "305", "308", "311", "314", "317", "320"] | index($code) then if n then "¯îÑ" else "¾░ûù" end
					elif ["323", "326", "353", "356", "359"] | index($code) then if n then "¯îñ" else "¾░ûû" end
					elif ["179", "329", "332", "335", "338", "368", "371"] | index($code) then if n then "¯îğ" else "¾░ûİ" end
					elif ["227", "230"] | index($code) then if n then "¯ıí" else "¾░╝Â" end
					elif ["182", "185", "350", "362", "365", "374", "377"] | index($code) then if n then "¯Ä¼" else "¾░Ö┐" end
					elif ["200", "386", "389", "392", "395"] | index($code) then if n then "¯î¬" else "¾░ûô" end
					else if n then "¯ı¥" else "¾░ûÉ" end
					end;
				def condition($code; $text):
					if n and $code == "113" then "Clear"
					else ($text | gsub("[[:space:]]+"; " "))
					end;
				.current_condition[0] as $c
				| icon($c.weatherCode)
					+ " "
					+ ($c.temp_C | tostring)
					+ "┬░ "
					+ condition($c.weatherCode; ($c.weatherDesc[0].value // ""))
			' "$cache" 2>/dev/null || fallback
		else
			fallback
		fi
		;;
	*)
		fallback
		;;
esac
