#!/usr/bin/env sh
set -u

mode="${TERMUX_LAUNCHER_TMUX_WEATHER_MODE:-compact}"
cache="${XDG_CACHE_HOME:-$HOME/.cache}/launcher-weather-widget.json"

fallback() {
	launcher-weather-widget 2>/dev/null || printf '󰖐 --'
}

case "$mode" in
	condition|full|verbose)
		fallback >/dev/null
		if [ -r "$cache" ] && command -v jq >/dev/null 2>&1; then
			hour="$(date +%H)"
			if [ "$hour" -ge 18 ] || [ "$hour" -lt 6 ]; then
				night=1
			else
				night=0
			fi

			jq -r --arg night "$night" '
				def n: $night == "1";
				def icon($code):
					if ["113"] | index($code) then if n then "󰖔" else "󰖙" end
					elif ["116"] | index($code) then if n then "" else "󰖕" end
					elif ["119", "122"] | index($code) then if n then "" else "󰖐" end
					elif ["143", "248", "260"] | index($code) then if n then "" else "󰖑" end
					elif ["176", "263", "266", "293", "296", "299", "302", "305", "308", "311", "314", "317", "320"] | index($code) then if n then "" else "󰖗" end
					elif ["323", "326", "353", "356", "359"] | index($code) then if n then "" else "󰖖" end
					elif ["179", "329", "332", "335", "338", "368", "371"] | index($code) then if n then "" else "󰖘" end
					elif ["227", "230"] | index($code) then if n then "" else "󰼶" end
					elif ["182", "185", "350", "362", "365", "374", "377"] | index($code) then if n then "" else "󰙿" end
					elif ["200", "386", "389", "392", "395"] | index($code) then if n then "" else "󰖓" end
					else if n then "" else "󰖐" end
					end;
				def condition($code; $text):
					if n and $code == "113" then "Clear"
					else ($text | gsub("[[:space:]]+"; " "))
					end;
				.current_condition[0] as $c
				| icon($c.weatherCode)
					+ " "
					+ ($c.temp_C | tostring)
					+ "° "
					+ condition($c.weatherCode; ($c.weatherDesc[0].value // ""))
			' "$cache" 2>/dev/null || fallback
		else
			fallback
		fi
		;;
	*)
		fallback
		;;
esac
