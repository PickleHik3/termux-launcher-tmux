#!/usr/bin/env sh
set -eu

PATH="/data/data/com.termux/files/usr/bin:/system/bin:/system/xbin:${PATH:-}"
mode="${1:-right}"
cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}/termux-launcher-tmux"
cache_file="$cache_dir/resources.json"
fallback_cache="${XDG_CACHE_HOME:-$HOME/.cache}/launcher-system-monitor.json"
lock_dir="$cache_dir/resources.lock"
ttl="${TERMUX_LAUNCHER_TMUX_RESOURCE_TTL:-5}"
stale_ttl="${TERMUX_LAUNCHER_TMUX_RESOURCE_STALE_TTL:-60}"

command -v jq >/dev/null 2>&1 || exit 0
mkdir -p "$cache_dir"

now_epoch() { date +%s; }

file_age() {
	[ -r "$1" ] || { printf '999999'; return; }
	now="$(now_epoch)"
	mt="$(stat -c %Y "$1" 2>/dev/null || printf '0')"
	[ "$mt" -gt 0 ] || { printf '999999'; return; }
	printf '%s' "$((now - mt))"
}

refresh_cache() {
	command -v launcherctl >/dev/null 2>&1 || return 1
	tmp="$cache_file.tmp.$$"
	if launcherctl resources > "$tmp" 2>/dev/null && jq -e '.ok == true' "$tmp" >/dev/null 2>&1; then
		mv "$tmp" "$cache_file"
		return 0
	fi
	rm -f "$tmp"
	return 1
}

load_json() {
	age="$(file_age "$cache_file")"
	if [ "$age" -gt "$ttl" ]; then
		if [ -d "$lock_dir" ] && [ "$(file_age "$lock_dir")" -gt "$stale_ttl" ]; then
			rmdir "$lock_dir" 2>/dev/null || true
		fi
		if mkdir "$lock_dir" 2>/dev/null; then
			refresh_cache || true
			rmdir "$lock_dir" 2>/dev/null || true
		fi
	fi

	age="$(file_age "$cache_file")"
	if [ "$age" -le "$stale_ttl" ]; then
		cat "$cache_file"
		return
	fi

	age="$(file_age "$fallback_cache")"
	[ "$age" -le "$stale_ttl" ] || exit 0
	cat "$fallback_cache"
}

json="$(load_json)"
[ -n "$json" ] || exit 0

is_on() {
	case "${1:-off}" in
		on|ON|true|TRUE|1|yes|YES) return 0 ;;
		*) return 1 ;;
	esac
}

fmt_pct() {
	awk -v v="${1:-0}" 'BEGIN { p = int(v + 0.5); if (p < 0) p = 0; if (p > 100) p = 100; printf "%02d%%", p }'
}

percent() {
	awk -v used="${1:-0}" -v total="${2:-0}" 'BEGIN {
		if (total <= 0) exit 1;
		p = (used * 100) / total;
		if (p < 0) p = 0; if (p > 100) p = 100;
		printf "%.0f", p;
	}'
}

battery_icon() {
	level="$1"
	charging="$2"
	if [ "$charging" = "true" ]; then printf '󰂄'
	elif [ "$level" -le 10 ]; then printf '󰁺'
	elif [ "$level" -le 20 ]; then printf '󰁻'
	elif [ "$level" -le 30 ]; then printf '󰁼'
	elif [ "$level" -le 40 ]; then printf '󰁽'
	elif [ "$level" -le 50 ]; then printf '󰁾'
	elif [ "$level" -le 60 ]; then printf '󰁿'
	elif [ "$level" -le 70 ]; then printf '󰂀'
	elif [ "$level" -le 80 ]; then printf '󰂁'
	elif [ "$level" -le 90 ]; then printf '󰂂'
	else printf '󰁹'
	fi
}

temp_icon() {
	temp="$1"
	awk -v t="$temp" 'BEGIN {
		if (t <= 35) print "";
		else if (t <= 45) print "";
		else if (t <= 60) print "";
		else if (t <= 75) print "";
		else print "";
	}'
}

fmt_temp() {
	awk -v v="${1:-0}" 'BEGIN { printf "%.0f°", v }'
}

inline_reading() {
	fg="$1"
	text="$2"
	printf '#[fg=%s,bg=%s] / #[fg=%s,bg=%s]%s' "$inline_sep_fg" "$bg" "$fg" "$bg" "$text"
}

join_segment() {
	part="$1"
	[ -n "$part" ] || return 0
	if [ -n "$out" ]; then
		out="${out}#[fg=${sep_fg},bg=${bg}] · ${part}"
	else
		out="$part"
	fi
}

cpu_percent() { printf '%s' "$json" | jq -r '.cpuPercent // empty'; }
ram_percent() {
	printf '%s' "$json" | jq -r 'if (.memTotalBytes // 0) > 0 then ((.memUsedBytes / .memTotalBytes) * 100 | round) else empty end'
}
storage_percent() {
	printf '%s' "$json" | jq -r '
		((.storage // [] | map(select(.label == "shared"))[0])
		// (.storage // [] | map(select(.label == "data"))[0])
		// empty) as $s
		| if (($s.totalBytes // 0) > 0) then (($s.usedBytes / $s.totalBytes) * 100 | round) else empty end'
}
battery_level() { printf '%s' "$json" | jq -r '.battery.levelPercent // empty'; }
battery_charging() { printf '%s' "$json" | jq -r '.battery.charging // false'; }
battery_temp() { printf '%s' "$json" | jq -r '.battery.temperatureC // empty'; }
package_temp() {
	printf '%s' "$json" | jq -r '
		def valid: select((.tempC > -100) and (.tempC < 200));
		((.thermal // [] | map(valid | select(.type | test("cpuss"; "i"))) | max_by(.tempC).tempC)
		// ((.thermal // [] | map(valid | select(.type | test("package"; "i"))) | max_by(.tempC).tempC)
		// ((.thermal // [] | map(valid | select(.type | test("soc|aoss"; "i"))) | max_by(.tempC).tempC)
		// ((.thermal // [] | map(valid | select(.type | test("cpu"; "i"))) | max_by(.tempC).tempC)
		// empty))))'
}

cpu_segment() {
	cpu="$(cpu_percent)"
	[ -n "$cpu" ] || return 0
	seg=" $(fmt_pct "$cpu")"
	if is_on "${TERMUX_LAUNCHER_TMUX_SHOW_CPU_TEMP:-off}"; then
		temp="$(package_temp)"
		if [ -n "$temp" ]; then
			seg="${seg}$(inline_reading "$temp_fg" "$(temp_icon "$temp") $(fmt_temp "$temp")")"
		fi
	fi
	printf '%s' "$seg"
}

ram_segment() {
	ram="$(ram_percent)"
	[ -n "$ram" ] || return 0
	printf ' %s' "$(fmt_pct "$ram")"
}

storage_segment() {
	stor="$(storage_percent)"
	[ -n "$stor" ] || return 0
	printf '󰋊 %s' "$(fmt_pct "$stor")"
}

battery_segment() {
	level="$(battery_level)"
	[ -n "$level" ] || return 0
	level="$(awk -v v="$level" 'BEGIN { p = int(v + 0.5); if (p < 0) p = 0; if (p > 100) p = 100; print p }')"
	charging="$(battery_charging)"
	seg="$(battery_icon "$level" "$charging") $(fmt_pct "$level")"
	if is_on "${TERMUX_LAUNCHER_TMUX_SHOW_BATTERY_TEMP:-off}"; then
		temp="$(battery_temp)"
		if [ -n "$temp" ]; then
			seg="${seg}$(inline_reading "$battery_temp_fg" "$(temp_icon "$temp") $(fmt_temp "$temp")")"
		fi
	fi
	printf '%s' "$seg"
}

bg="${TERMUX_LAUNCHER_TMUX_WIDGET_BG:-default}"
sep_fg="${TERMUX_LAUNCHER_TMUX_SEPARATOR_FG:-default}"
inline_sep_fg="${TERMUX_LAUNCHER_TMUX_INLINE_SEPARATOR_FG:-$sep_fg}"
cpu_fg="${TERMUX_LAUNCHER_TMUX_CPU_FG:-default}"
ram_fg="${TERMUX_LAUNCHER_TMUX_RAM_FG:-default}"
storage_fg="${TERMUX_LAUNCHER_TMUX_STORAGE_FG:-default}"
battery_fg="${TERMUX_LAUNCHER_TMUX_BATTERY_FG:-default}"
temp_fg="${TERMUX_LAUNCHER_TMUX_CPU_TEMP_FG:-default}"
battery_temp_fg="${TERMUX_LAUNCHER_TMUX_BATTERY_TEMP_FG:-default}"

case "$mode" in
	right)
		out=""
		if is_on "${TERMUX_LAUNCHER_TMUX_SHOW_SYSTEM:-on}"; then
			part="$(cpu_segment)"
			[ -n "$part" ] && join_segment "#[fg=${cpu_fg},bg=${bg}]${part}"
			part="$(ram_segment)"
			[ -n "$part" ] && join_segment "#[fg=${ram_fg},bg=${bg}]${part}"
		elif is_on "${TERMUX_LAUNCHER_TMUX_SHOW_CPU_TEMP:-off}"; then
			part="$(cpu_segment)"
			[ -n "$part" ] && join_segment "#[fg=${temp_fg},bg=${bg}]${part}"
		fi
		if is_on "${TERMUX_LAUNCHER_TMUX_SHOW_STORAGE:-off}"; then
			part="$(storage_segment)"
			[ -n "$part" ] && join_segment "#[fg=${storage_fg},bg=${bg}]${part}"
		fi
		if is_on "${TERMUX_LAUNCHER_TMUX_SHOW_BATTERY:-off}"; then
			part="$(battery_segment)"
			[ -n "$part" ] && join_segment "#[fg=${battery_fg},bg=${bg}]${part}"
		fi
		printf '%s' "$out"
		;;
	cpu-temp)
		temp="$(package_temp)"
		[ -n "$temp" ] || exit 0
		printf '%s %s°C' "$(temp_icon "$temp")" "$(awk -v v="$temp" 'BEGIN { printf "%.0f", v }')"
		;;
	battery-temp)
		temp="$(battery_temp)"
		[ -n "$temp" ] || exit 0
		printf '%s %s°C' "$(temp_icon "$temp")" "$(awk -v v="$temp" 'BEGIN { printf "%.0f", v }')"
		;;
	*)
		exit 0
		;;
esac
